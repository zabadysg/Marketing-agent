# =============================================================================
# Application
# =============================================================================
APP_ENV=development
# WARNING: Setting DEBUG=true enables /api/docs (Swagger UI) — never enable in production.
DEBUG=false
# Required: protects all /api/admin/* endpoints. Generate with: openssl rand -hex 32
ADMIN_API_KEY=generate-a-strong-random-secret-here
# Comma-separated allowed CORS origins (default covers local dev)
# ALLOWED_ORIGINS=["*"]

# =============================================================================
# Our database (FastAPI app)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/marketing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=marketing

# =============================================================================
# Gemini / LangChain
# =============================================================================
GOOGLE_API_KEY=your-google-api-key-here
REASONING_MODEL=gemini-2.5-pro
CHEAP_MODEL=gemini-2.5-flash
MAX_TOKENS=8192

# =============================================================================
# LangSmith (optional tracing — set LANGSMITH_TRACING=true to enable)
# =============================================================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=marketing-agent

# =============================================================================
# Postiz integration (used by our FastAPI client)
# =============================================================================
POSTIZ_API_URL=http://postiz:5000
POSTIZ_API_KEY=your-postiz-api-key-here

# =============================================================================
# Postiz container config (used by the postiz service itself)
# =============================================================================
# Required: min 32 chars. Generate with: openssl rand -hex 32
POSTIZ_JWT_SECRET=generate-a-strong-random-secret-here

# Public-facing domain (used in MAIN_URL / FRONTEND_URL / NEXT_PUBLIC_BACKEND_URL)
# For local-only dev without a domain, set these to http://localhost:5000
DOMAIN=marketing.yourdomain.com

# Social channel OAuth credentials (passed to the Postiz container)
# LinkedIn: https://developer.linkedin.com/ → create app → Auth tab
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# X (Twitter): https://developer.twitter.com/ → create app → Keys and Tokens tab
# Use OAuth 1.0a Consumer Key/Secret (NOT the OAuth 2.0 Client ID/Secret)
X_API_KEY=
X_API_SECRET=

# Postiz database (separate from our app DB)
POSTIZ_DB_USER=postiz_user
POSTIZ_DB_PASSWORD=postiz_pass
POSTIZ_DB_NAME=postiz

# =============================================================================
# Nginx / SSL (GCP VM production only)
# =============================================================================
CERTBOT_EMAIL=admin@yourdomain.com
